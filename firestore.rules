rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Função auxiliar para verificar se o usuário é o Admin (está autenticado)
    function isAdmin() {
      return request.auth != null;
    }

    // Regras para a coleção de imóveis
    match /properties/{propertyId} {
      // O Admin lê tudo. O público lê apenas imóveis ativos.
      allow read: if isAdmin() || resource.data.active == true;

      // Criação e exclusão totais restritas ao Admin
      allow create, delete: if isAdmin();

      // Atualização: Escrita totalmente restrita ao Admin.
      // Funcionalidades de incremento público foram removidas para prevenir abuso de bots.
      allow update: if isAdmin();
    }

    // Regras para a coleção de leads (contatos)
    match /leads/{leadId} {
      // Qualquer um na internet pode criar (enviar um contato/whatsapp)
      allow create: if true;

      // Apenas o Admin consegue ler a lista, atualizar status ou deletar um lead
      allow read, update, delete: if isAdmin();
    }

    // Regras para as coleções de Analytics
    match /analytics_daily/{docId} {
      allow read, delete: if isAdmin();
      allow create, update: if true;
    }

    match /analytics_filters/{docId} {
      allow read, delete: if isAdmin();
      allow create, update: if true;
    }

    match /analytics_bairros/{docId} {
      allow read, delete: if isAdmin();
      allow create, update: if true;
    }

    // Regras para links de campanha (UTM)
    match /campaign_links/{linkId} {
      // Apenas o Admin pode criar, ler e deletar links de campanha
      allow read, create, delete: if isAdmin();
    }

    // Regras para tracking de cliques das campanhas UTM
    match /campaign_clicks/{docId} {
      // Público pode gravar os cliques, admin pode ler e deletar
      allow read, delete: if isAdmin();
      allow create, update: if true;
    }
  }
}