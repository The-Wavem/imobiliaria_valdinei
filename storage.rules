rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Escrita restrita a administradores autenticados em todo o bucket.
    // Leitura pública para que imagens dos imóveis e XML feeds funcionem.
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
